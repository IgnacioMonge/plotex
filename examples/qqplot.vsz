# Plotex saved document (version 4.2)
# Q-Q Plot example — normality check

AddImportPath(u'.')

# Generate sample data: approximately normal with slight skew
# (70 observations from a slightly skewed distribution)
ImportString(u'measurements(numeric)','''
2.14
3.51
4.02
4.38
4.55
4.71
4.89
5.01
5.12
5.23
5.31
5.42
5.48
5.55
