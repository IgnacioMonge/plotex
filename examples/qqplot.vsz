''')

Set('width', '16cm')
Set('height', '14cm')

Add('page', name='page1', autoadd=False)
To('page1')
Set('width', '16cm')
Set('height', '14cm')

Add('graph', name='graph1', autoadd=False)
To('graph1')

Add('axis', name='x', autoadd=False)
To('x')
Set('label', u'Theoretical quantiles (Normal)')
To('..')

Add('axis', name='y', autoadd=False)
To('y')
Set('label', u'Observed quantiles')
Set('direction', 'vertical')
To('..')

Add('qqplot', name='qq1', autoadd=False)
To('qq1')
Set('data', u'measurements')
Set('distribution', u'normal')
Set('showRefLine', True)
Set('showCI', True)
Set('marker', u'circle')
Set('markerSize', u'3pt')
Set('MarkerFill/color', u'#4a90d9')
Set('RefLine/color', u'#888888')
Set('RefLine/style', u'dashed')
Set('CIFill/color', u'#4a90d9')
Set('CIFill/transparency', 80)
To('..')

Add('label', name='title', autoadd=False)
To('title')
Set('label', u'Q-Q Plot: Normality Assessment')
Set('xPos', 0.5)
Set('yPos', 1.02)
Set('alignHorz', u'centre')
Set('Text/size', u'14pt')
Set('Text/bold', True)
To('..')

To('..')
To('..')
