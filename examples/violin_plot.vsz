SetDataText('vlabels', [
    'Normal',
    'Skewed',
    'Bimodal',
    'Uniform',
])

Set('width', '18cm')
Set('height', '28cm')
Add('page', name='page1', autoadd=False)
To('page1')

Add('grid', name='grid1', autoadd=False)
To('grid1')
Set('columns', 1)
Set('rows', 4)

# --- Plot 1: Box interior (default) ---
Add('graph', name='graph1', autoadd=False)
To('graph1')
Add('axis', name='x', autoadd=False)
To('x')
Set('label', 'Distribution')
Set('mode', 'labels')
To('..')
Add('axis', name='y', autoadd=False)
To('y')
Set('label', 'Value')
Set('direction', 'vertical')
To('..')
Add('violin', name='violin1', autoadd=False)
To('violin1')
Set('values', ['normal', 'skewed', 'bimodal', 'uniform'])
Set('labels', 'vlabels')
Set('inner', 'box')
Set('showMean', True)
Set('MeanLine/color', 'red')
Set('MeanLine/style', 'dashed')
To('..')
To('..')

# --- Plot 2: Split violin (two datasets compared) ---
Add('graph', name='graph2', autoadd=False)
To('graph2')
Add('axis', name='x', autoadd=False)
To('x')
Set('label', 'Comparison')
Set('mode', 'labels')
To('..')
Add('axis', name='y', autoadd=False)
To('y')
Set('label', 'Value')
Set('direction', 'vertical')
To('..')
Add('violin', name='violin2', autoadd=False)
To('violin2')
Set('values', ['normal', 'skewed', 'bimodal', 'uniform'])
Set('splitValues', ['skewed', 'uniform', 'normal', 'bimodal'])
Set('labels', 'vlabels')
Set('side', 'split')
Set('inner', 'quartile')
Set('Fill/color', '#4488cc')
Set('Fill/transparency', 20)
To('..')
To('..')

# --- Plot 3: Raincloud plot ---
Add('graph', name='graph3', autoadd=False)
To('graph3')
Add('axis', name='x', autoadd=False)
To('x')
Set('label', 'Distribution')
Set('mode', 'labels')
To('..')
Add('axis', name='y', autoadd=False)
To('y')
Set('label', 'Value')
Set('direction', 'vertical')
To('..')
Add('violin', name='violin3', autoadd=False)
To('violin3')
Set('values', ['normal', 'skewed', 'bimodal', 'uniform'])
Set('labels', 'vlabels')
Set('side', 'low')
Set('inner', 'raincloud')
Set('Fill/color', '#88cc44')
Set('Fill/transparency', 20)
Set('jitter', 0.9)
Set('markerSize', '1.5pt')
To('..')
To('..')

# --- Plot 4: Horizontal with points ---
Add('graph', name='graph4', autoadd=False)
To('graph4')
Add('axis', name='x', autoadd=False)
To('x')
Set('label', 'Value')
To('..')
Add('axis', name='y', autoadd=False)
To('y')
Set('label', 'Distribution')
Set('direction', 'vertical')
Set('mode', 'labels')
To('..')
Add('violin', name='violin4', autoadd=False)
To('violin4')
Set('values', ['normal', 'skewed', 'bimodal', 'uniform'])
Set('labels', 'vlabels')
Set('direction', 'horizontal')
Set('inner', 'points')
Set('Fill/color', '#cc6644')
Set('Fill/transparency', 30)
Set('jitter', 0.7)
To('..')
To('..')

To('..')
To('..')
