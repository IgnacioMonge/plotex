# Plotex saved document (version 4.2)
# Bland-Altman example — method comparison (glucose meters)

AddImportPath(u'.')

# Two glucose meters measuring the same 30 patients (mg/dL)
ImportString(u'meter_A(numeric)','''
95
102
87
120
110
98
130
115
105
140
92
88
125
108
135
100
112
96
118
128
90
106
142
99
116
85
122
