Set('width', '17cm')
Set('height', '13cm')

Add('page', name='page1', autoadd=False)
To('page1')
Set('width', '17cm')
Set('height', '13cm')

Add('graph', name='graph1', autoadd=False)
To('graph1')

Add('axis', name='x', autoadd=False)
To('x')
Set('label', u'Mean of two methods (mg/dL)')
To('..')

Add('axis', name='y', autoadd=False)
To('y')
Set('label', u'Difference (Meter A \u2212 Meter B)')
Set('direction', 'vertical')
To('..')

Add('blandaltman', name='ba1', autoadd=False)
To('ba1')
Set('method1Data', u'meter_A')
Set('method2Data', u'meter_B')
Set('showBias', True)
Set('showLOA', True)
Set('showZero', True)
Set('showConfBands', True)
Set('showLineLabels', True)
Set('marker', u'circle')
Set('markerSize', u'3pt')
To('..')

Add('label', name='title', autoadd=False)
To('title')
Set('label', u'Bland-Altman: Glucose Meter Comparison')
Set('xPos', 0.5)
Set('yPos', 1.02)
Set('alignHorz', u'centre')
Set('Text/size', u'14pt')
Set('Text/bold', True)
To('..')

To('..')
To('..')
